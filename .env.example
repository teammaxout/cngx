# ─────────────────────────────────────────────
# cngx Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── LLM Provider API Keys ──
# At least one is required for live testing.
# Mock adapter works without any keys.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Either name works for the Gemini adapter:
GOOGLE_API_KEY=
GEMINI_API_KEY=

# ── Local proxy (optional) ──
CNGX_PROXY_HOST=127.0.0.1
CNGX_PROXY_PORT=8642

# ── Optional ──
CNGX_LOG_LEVEL=INFO
CNGX_STORAGE_DIR=.cngx
