# ─────────────────────────────────────────────
# Cogscope Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── LLM Provider API Keys ──
# At least one is required for live testing.
# Mock adapter works without any keys.
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Server (optional self-hosted UI) ──
COGSCOPE_HOST=0.0.0.0
COGSCOPE_PORT=8642
COGSCOPE_SECRET_KEY=change-me-to-a-random-secret

# ── Optional ──
COGSCOPE_LOG_LEVEL=INFO
COGSCOPE_STORAGE_DIR=.cogscope
